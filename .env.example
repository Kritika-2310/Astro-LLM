# Groq - for generating training data (fast inference, free tier)
# Get at: console.groq.com
GROQ_API_KEY=

# Gemini - used as LLM judge during evaluation
# Get at: aistudio.google.com
GEMINI_API_KEY=

# HuggingFace - needed to download Llama 3 8B weights
# 1. Create account at huggingface.co
# 2. Accept Llama 3 license at huggingface.co/meta-llama/Meta-Llama-3-8B-Instruct
# 3. Generate token at huggingface.co/settings/tokens
HF_TOKEN=

# Base model to fine-tune
BASE_MODEL_ID=meta-llama/Meta-Llama-3-8B-Instruct

# Experiment tracking (free at wandb.ai)
WANDB_API_KEY=
WANDB_PROJECT=astro-llm
